# Monarch inference service - environment template.
# Copy to `.env` and fill in. `.env` is gitignored; never commit real secrets.

# === Hugging Face (REQUIRED for real inference) ===
# TRIBE v2 weights and the gated LLaMA-3.2-3B feature extractor download from
# Hugging Face. Without this the model load fails with HTTP 401.
#   1. Accept the license at https://huggingface.co/meta-llama/Llama-3.2-3B
#   2. Create a READ token at https://huggingface.co/settings/tokens
#   3. Paste it below (or run `huggingface-cli login`).
# The huggingface_hub library reads HF_TOKEN automatically.
HF_TOKEN=

# === Gateway auth ===
# Bearer token the Convex gateway sends. Empty disables auth (dev only) and the
# app logs a loud warning at startup. Set before exposing the service publicly.
INFERENCE_API_KEY=

# === Gemma audit report via Fireworks AI (AMD-hosted) ===
# Empty disables the LLM call; the report service falls back to a deterministic
# template. Get a key at https://fireworks.ai (new signups get free credit).
FIREWORKS_API_KEY=

# === Model load / device ===
# Set to 1 on a CPU-only dev box to boot the app without downloading weights;
# /api/scan then returns 503. Set 0 (or unset) on the MI300X pod for real runs.
MONARCH_SKIP_MODEL_LOAD=1
# "auto" picks ROCm/CUDA when present, else CPU.
MONARCH_TRIBE_DEVICE=auto

# === Optional: Redis-backed activation cache (defaults to in-memory) ===
# MONARCH_REDIS_URL=redis://localhost:6379/0

# === Optional: CORS origins (comma-separated) ===
# MONARCH_CORS_ORIGINS=http://localhost:3000,https://monarch.brianmwai.com
